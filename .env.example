# Copy to .env and fill in. .env is git-ignored — never commit real keys.

# CoinMarketCap Skill Hub (MCP, Streamable HTTP)
CMC_MCP_URL=https://mcp.coinmarketcap.com/skill-hub/stream
CMC_MCP_API_KEY=your_cmc_skill_hub_key

# xAI / Grok
GROK_API_KEY=your_xai_key
GROK_MODEL=grok-4
GROK_BASE_URL=https://api.x.ai/v1

# CreatorCrawl (tweets)
CREATORCRAWL_API_KEY=your_creatorcrawl_key
CREATORCRAWL_BASE_URL=https://creatorcrawl.com/api

# Optional: limit concurrency of per-token work in the snapshot job
SNAPSHOT_CONCURRENCY=3
